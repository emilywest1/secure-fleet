# nrpe.cfg.j2 — Ansible-managed NRPE configuration
# Managed by Ansible — do not edit manually

log_facility={{ nrpe_log_facility }}
pid_file={{ nrpe_pid_file }}
server_port={{ nrpe_port }}
nrpe_user={{ nrpe_user }}
nrpe_group={{ nrpe_group }}

# Hosts allowed to connect (comma-separated IPs)
allowed_hosts={{ nrpe_allowed_hosts }}

dont_blame_nrpe=0
allow_bash_command_substitution=0
debug=0
command_timeout=60
connection_timeout=300

# ── Basic check commands ──────────────────────────────────────────────────────
command[check_users]=/usr/lib/nagios/plugins/check_users -w 5 -c 10
command[check_load]=/usr/lib/nagios/plugins/check_load -r -w .15,.10,.05 -c .30,.25,.20
command[check_hda1]=/usr/lib/nagios/plugins/check_disk -w 20% -c 10% -p /
command[check_zombie_procs]=/usr/lib/nagios/plugins/check_procs -w 5 -c 10 -s Z
command[check_total_procs]=/usr/lib/nagios/plugins/check_procs -w 150 -c 200
command[check_swap]=/usr/lib/nagios/plugins/check_swap -w 20% -c 10%
command[check_mem]=/usr/lib/nagios/plugins/check_mem -f -w 20 -c 10
